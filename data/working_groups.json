{
  "last_updated": "2026-03-12",
  "source": "ISA — https://isa.org.jm/the-mining-code/working-groups/",
  "description": "All intersessional working groups, informal working groups, and Friends of the President groups that contributed to the ISA exploitation regulations drafting process. Their outputs fed directly into the successive consolidated texts.",
  "phases": {
    "phase_1": {
      "label": "Phase 1 — Financial Terms Working Group",
      "period": "2019–2024",
      "sessions": "ISBA/25–29",
      "description": "Pre-dating the formal IWG structure, the OEWG on Financial Terms was the first sustained intersessional body. Its outputs fed Part VII of the consolidated texts."
    },
    "phase_2": {
      "label": "Phase 2 — Thematic Informal Working Groups",
      "period": "2022–2024",
      "sessions": "ISBA/27–29",
      "description": "Following the ISBA/26/C/11 decision on working methods (2020), four thematic IWGs were established to work systematically through the draft text. Their outputs were incorporated into ISBA/29/C/CRP.1 and ISBA/30/C/CRP.1."
    },
    "phase_3": {
      "label": "Phase 3 — Thematic Approach + Friends of the President",
      "period": "2025–2026",
      "sessions": "ISBA/30–31",
      "description": "Following ISBA/30/C/18 (thematic approach decision), a new set of intersessional IWGs and the new Friends of the President (FOP) modality were established to target remaining outstanding issues. Their outputs fed into ISBA/31/C/CRP.1/Rev.2."
    }
  },
